---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{title}</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">
    </head>
    <body class="bg-[#333333] text-white antialiased min-h-screen relative overflow-x-hidden">
        
        <canvas id="tech-bg" class="fixed inset-0 -z-20 opacity-50 pointer-events-none"></canvas>

        <div class="fixed inset-0 z-[100] pointer-events-none opacity-[0.04] bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>
        <div class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_50%_0%,_#444444_0%,_transparent_75%)]"></div>

        <nav class="fixed top-6 inset-x-0 z-[110] flex justify-center px-6">
            <div class="flex items-center justify-between w-full max-w-5xl px-8 py-4 bg-white/[0.05] backdrop-blur-2xl border border-white/20 rounded-2xl shadow-2xl">
                <div class="text-xl font-black tracking-tighter uppercase italic">
                    LOCAL<span class="text-[#facc15]">MKT</span>
                </div>
                <div class="hidden md:flex gap-10 text-[10px] uppercase tracking-[0.4em] font-bold text-white/50">
                    <a href="/" class="hover:text-[#facc15] transition-colors">Colecciones</a>
                    <a href="#" class="hover:text-[#facc15] transition-colors">Drops</a>
                </div>
                <div class="flex items-center gap-5">
                    <a href="/carrito" class="relative bg-white/10 p-2.5 rounded-xl border border-white/10 hover:bg-[#facc15] hover:text-black transition-all group flex items-center justify-center">
                        <span class="text-xs">🛒</span>
                        <span id="cart-count" class="absolute -top-1 -right-1 bg-[#facc15] text-black text-[9px] font-bold px-1.5 rounded-sm shadow-sm">
                            0
                        </span>
                    </a>
                </div>
            </div>
        </nav>

        <main class="relative z-10 pt-32">
            <slot />
        </main>

        <Footer />

        <div id="toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 z-[200] pointer-events-none opacity-0 transition-all duration-500 transform translate-y-10">
            <div class="bg-white text-black px-8 py-4 rounded-2xl shadow-2xl flex items-center gap-4 border border-white/20">
                <span class="text-[#facc15] bg-black rounded-full w-6 h-6 flex items-center justify-center text-[10px] font-bold">✓</span>
                <p class="uppercase text-[10px] font-black tracking-[0.2em]">Producto añadido al kit</p>
            </div>
        </div>

        <div id="custom-cursor" class="fixed w-8 h-8 border border-[#facc15] rounded-full pointer-events-none z-[999] transition-transform duration-100 ease-out opacity-0 hidden md:block"></div>

        <script>
            import { cartItems } from '../store/cartStore.js';

            // --- 1. LÓGICA DEL CARRITO ---
            const updateCart = (items) => {
                const countElement = document.getElementById('cart-count');
                if (countElement) countElement.innerText = items.length.toString();
            };

            // --- 2. SCROLL REVEAL ---
            const setupReveal = () => {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('active');
                            observer.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.1 });
                document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
            };

            // --- 3. CURSOR CUSTOM ---
            const setupCursor = () => {
                const cursor = document.getElementById('custom-cursor');
                document.addEventListener('mousemove', (e) => {
                    if (cursor) {
                        cursor.style.opacity = "1";
                        cursor.style.left = `${e.clientX - 16}px`;
                        cursor.style.top = `${e.clientY - 16}px`;
                    }
                });

                const interactivos = document.querySelectorAll('a, button, .product-item');
                interactivos.forEach(el => {
                    el.addEventListener('mouseenter', () => cursor?.classList.add('scale-150', 'bg-[#facc15]/20'));
                    el.addEventListener('mouseleave', () => cursor?.classList.remove('scale-150', 'bg-[#facc15]/20'));
                });
            };

            // --- 4. FONDO DE PARTÍCULAS ---
            const canvas = document.getElementById('tech-bg') as HTMLCanvasElement;
            const ctx = canvas?.getContext('2d');
            let particles: any[] = [];
            const mouse = { x: 0, y: 0, active: false };

            const initParticles = () => {
                if (!canvas || !ctx) return;
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
                particles = [];
                for (let i = 0; i < 110; i++) {
                    particles.push({
                        x: Math.random() * canvas.width,
                        y: Math.random() * canvas.height,
                        vx: Math.random() * 0.4 - 0.2,
                        vy: Math.random() * 0.4 - 0.2,
                        size: 1.5
                    });
                }
            };

            const drawParticles = () => {
                if (!ctx || !canvas) return;
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                
                particles.forEach((p, i) => {
                    p.x += p.vx; p.y += p.vy;
                    if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
                    if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

                    if (mouse.active) {
                        const dx = mouse.x - p.x;
                        const dy = mouse.y - p.y;
                        const dist = Math.hypot(dx, dy);
                        if (dist < 150) {
                            const force = (150 - dist) / 150;
                            p.x -= (dx / dist) * force * 8;
                            p.y -= (dy / dist) * force * 8;
                        }
                    }

                    ctx.fillStyle = "rgba(250, 204, 21, 0.7)";
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                    ctx.fill();

                    for (let j = i + 1; j < particles.length; j++) {
                        const p2 = particles[j];
                        const d = Math.hypot(p.x - p2.x, p.y - p2.y);
                        if (d < 160) {
                            ctx.strokeStyle = `rgba(250, 204, 21, ${0.15 - d/160})`;
                            ctx.lineWidth = 0.6;
                            ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(p2.x, p2.y); ctx.stroke();
                        }
                    }
                });
                requestAnimationFrame(drawParticles);
            };

            const startAll = () => {
                cartItems.subscribe(updateCart);
                setupReveal();
                setupCursor();
                initParticles();
            };

            window.addEventListener('mousemove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; mouse.active = true; });
            window.addEventListener('resize', initParticles);
            
            startAll();
            drawParticles();

            document.addEventListener('astro:after-swap', startAll);
        </script>
    </body>
</html>

<style is:global>
    .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.9s cubic-bezier(0.17, 0.55, 0.55, 1);
    }
    .reveal.active {
        opacity: 1;
        transform: translateY(0);
    }
    html {
        scroll-behavior: smooth;
        cursor: none;
    }
    @media (max-width: 768px) {
        html { cursor: auto; }
    }
</style>