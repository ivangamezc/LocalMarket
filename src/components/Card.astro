---
interface Props {
	id: string;
	title: string;
	price: string;
	category: string;
	image: string;
}

const { id, title, price, category, image } = Astro.props;
---

<div class="group relative bg-[#2a2a2a]/40 border border-white/5 rounded-[2.5rem] overflow-hidden hover:border-[#facc15]/30 transition-all duration-700 shadow-2xl flex flex-col h-full">
	
	<a href={`/productos/${id}`} class="relative aspect-[4/5] overflow-hidden bg-[#1a1a1a] block">
		<img src={image} alt={title} class="w-full h-full object-cover opacity-70 group-hover:opacity-100 group-hover:scale-110 transition-all duration-1000" />
		<div class="absolute inset-0 bg-gradient-to-t from-[#2a2a2a] via-transparent to-transparent opacity-80"></div>
		<div class="absolute top-6 left-6 bg-white/5 backdrop-blur-xl border border-white/10 px-4 py-2 rounded-2xl shadow-xl">
			<span class="text-[#facc15] font-black text-sm italic tracking-tighter">{price}€</span>
		</div>
	</a>
	
	<div class="p-8 flex flex-col flex-grow">
		<div class="mb-6">
			<span class="text-[9px] uppercase tracking-[0.4em] text-[#facc15] font-bold block mb-2">{category}</span>
			<a href={`/productos/${id}`}>
				<h3 class="text-xl font-black uppercase tracking-tight text-white italic leading-none group-hover:text-[#facc15] transition-colors duration-500">{title}</h3>
			</a>
		</div>
		
		<button 
			class="add-to-cart-home mt-auto w-full py-4 bg-white text-black text-[11px] font-black uppercase tracking-[0.2em] rounded-2xl hover:bg-[#facc15] transition-all duration-300"
			data-id={id}
			data-nombre={title}
			data-precio={price}
			data-imagen={image}
		>
			Añadir al Carrito
		</button>
	</div>
</div>

<script>
	import { addCartItem } from '../store/cartStore.js';

	const buttons = document.querySelectorAll('.add-to-cart-home');
	buttons.forEach(btn => {
		btn.addEventListener('click', (e) => {
			e.preventDefault();
			const item = {
				id: btn.getAttribute('data-id'),
				nombre: btn.getAttribute('data-nombre'),
				precio: btn.getAttribute('data-precio'),
				imagen: btn.getAttribute('data-imagen')
			};
			addCartItem(item);
			const originalText = btn.innerHTML;
			btn.innerHTML = "¡AÑADIDO!";
			setTimeout(() => { btn.innerHTML = originalText; }, 800);
		});
	});
</script>