---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="relative z-10 mt-20 border-t border-white/5 bg-[#2a2a2a]/30 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
            
            <div class="col-span-1 md:col-span-2">
                <div class="text-3xl font-black tracking-tighter uppercase italic mb-6">
                    LOCAL<span class="text-[#facc15]">MKT</span>
                </div>
                <p class="text-gray-400 text-sm max-w-sm leading-relaxed mb-8">
                    Redefiniendo el concepto de moda local. Calidad industrial, diseño resiliente y fabricación ética desde el corazón de la ciudad.
                </p>
                <div class="flex gap-4">
                    <a href="#" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#facc15] hover:text-black transition-all">IG</a>
                    <a href="#" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#facc15] hover:text-black transition-all">TW</a>
                    <a href="#" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#facc15] hover:text-black transition-all">TK</a>
                </div>
            </div>

            <div>
                <h4 class="text-[#facc15] text-[10px] font-black uppercase tracking-[0.3em] mb-6">Explorar</h4>
                <ul class="flex flex-col gap-4 text-sm font-medium text-gray-300">
                    <li><a href="/" class="hover:text-white transition-colors">Colecciones</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Drops Exclusivos</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Archivo</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Sostenibilidad</a></li>
                </ul>
            </div>

            <div>
                <h4 class="text-[#facc15] text-[10px] font-black uppercase tracking-[0.3em] mb-6">Ayuda</h4>
                <ul class="flex flex-col gap-4 text-sm font-medium text-gray-300">
                    <li><a href="/envios" class="hover:text-white transition-colors">Envíos</a></li>
                    <li><a href="/devoluciones" class="hover:text-white transition-colors">Devoluciones</a></li>
                    <li><a href="/faq" class="hover:text-white transition-colors">FAQ</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Contacto</a></li>
                </ul>
            </div>
        </div>

        <div class="mt-16 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-[10px] text-gray-500 uppercase tracking-widest">
                © {currentYear} LocalMarket. Proyecto Final DAM.
            </p>
            <div class="flex gap-8 text-[10px] text-gray-500 uppercase tracking-widest">
                <a href="#" class="hover:text-white transition-colors">Privacidad</a>
                <a href="#" class="hover:text-white transition-colors">Términos</a>
            </div>
        </div>
    </div>
</footer>