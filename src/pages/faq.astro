---
import Layout from '../layouts/Layout.astro';

const faqs = [
    {
        categoria: "LOGÍSTICA",
        pregunta: "¿Cuál es el tiempo de entrega del 'Envío Blindado'?",
        respuesta: "Nuestros envíos urbanos se procesan en un ciclo de 24/48h. Recibirás un código de rastreo encriptado una vez que el paquete salga de nuestra central logística."
    },
    {
        categoria: "DEVOLUCIONES",
        pregunta: "¿Cómo funcionan las devoluciones?",
        respuesta: "Dispones de 14 días desde la recepción del kit para solicitar una devolución. El producto debe mantener todas las etiquetas industriales y no presentar signos de uso en exteriores."
    },
    {
        categoria: "PRODUCTO",
        pregunta: "¿Qué materiales utilizáis en la línea 'Resiliente'?",
        respuesta: "Utilizamos una mezcla de nylon reforzado, tejidos hidrófugos y algodón de alto gramaje. Cada prenda está diseñada para resistir el desgaste urbano diario."
    },
    {
        categoria: "SOPORTE",
        pregunta: "¿Tenéis tienda física para probar el tallaje?",
        respuesta: "Actualmente operamos exclusivamente online para mantener la exclusividad de los drops, pero dispones de una guía técnica de tallas en cada ficha de producto."
    }
];
---

<Layout title="FAQ | LOCALMKT CENTER">
    <section class="px-6 py-24 max-w-4xl mx-auto min-h-screen">
        
        <div class="reveal mb-20 text-center">
            <div class="inline-flex items-center gap-2 px-3 py-1 border border-[#facc15]/30 bg-[#facc15]/5 rounded-full mb-6">
                <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#facc15] opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-[#facc15]"></span>
                </span>
                <span class="text-[#facc15] text-[9px] font-black uppercase tracking-[0.3em]">Sistema de Soporte Activo</span>
            </div>
            <h1 class="text-6xl md:text-8xl font-black italic uppercase tracking-tighter leading-none">
                Preguntas <br/> <span class="text-[#facc15]">Frecuentes</span>
            </h1>
        </div>

        <div class="grid gap-4">
            {faqs.map((faq, i) => (
                <div class="reveal border border-white/10 rounded-2xl bg-white/[0.02] hover:border-white/20 transition-colors">
                    <button class="faq-button w-full px-8 py-7 text-left flex justify-between items-center group">
                        <div class="flex flex-col gap-2">
                            <span class="text-[#facc15] text-[8px] font-bold tracking-[0.4em] uppercase opacity-60">
                                [{faq.categoria}]
                            </span>
                            <span class="uppercase text-xs md:text-sm font-black tracking-widest leading-relaxed">
                                {faq.pregunta}
                            </span>
                        </div>
                        <div class="relative flex items-center justify-center w-6 h-6">
                            <div class="absolute w-4 h-[2px] bg-[#facc15]"></div>
                            <div class="vertical-line absolute w-[2px] h-4 bg-[#facc15] transition-transform duration-300"></div>
                        </div>
                    </button>
                    
                    <div class="faq-answer max-h-0 overflow-hidden transition-all duration-500 ease-in-out opacity-0">
                        <div class="px-8 pb-8 flex gap-4">
                            <div class="w-[2px] bg-[#facc15]/30"></div>
                            <p class="text-gray-400 text-sm leading-relaxed font-light max-w-2xl italic">
                                {faq.respuesta}
                            </p>
                        </div>
                    </div>
                </div>
            ))}
        </div>

        <div class="reveal mt-20 flex flex-col md:flex-row items-center justify-between p-8 border-t border-white/10 gap-8">
            <div class="text-center md:text-left">
                <h3 class="font-black uppercase tracking-widest text-lg">¿Necesitas asistencia directa?</h3>
                <p class="text-gray-500 text-xs uppercase tracking-tighter mt-1">Tiempo de respuesta estimado: <span class="text-white">Menos de 12h</span></p>
            </div>
            <a href="mailto:support@localmarket.com" class="bg-[#facc15] text-black px-10 py-4 rounded-full font-black uppercase text-[10px] tracking-[0.2em] hover:scale-105 transition-transform active:scale-95">
                Abrir Ticket de Soporte
            </a>
        </div>

    </section>
</Layout>

<script>
    const setupFaqs = () => {
        const buttons = document.querySelectorAll('.faq-button');
        
        buttons.forEach(button => {
            button.addEventListener('click', () => {
                const answer = button.nextElementSibling as HTMLElement;
                const verticalLine = button.querySelector('.vertical-line') as HTMLElement;
                
                // Toggle para cerrar otros si se abre uno (opcional)
                // document.querySelectorAll('.faq-answer').forEach(el => { ... });

                if (answer.style.maxHeight && answer.style.maxHeight !== "0px") {
                    answer.style.maxHeight = "0px";
                    answer.style.opacity = "0";
                    if(verticalLine) verticalLine.style.transform = "rotate(0deg)";
                } else {
                    answer.style.maxHeight = answer.scrollHeight + "px";
                    answer.style.opacity = "1";
                    if(verticalLine) verticalLine.style.transform = "rotate(90deg)";
                }
            });
        });
    }

    // Inicialización
    setupFaqs();
    document.addEventListener('astro:after-swap', setupFaqs);
</script>

<style>
    /* Estilos locales específicos para FAQ */
    .faq-button:focus {
        outline: none;
    }
</style>