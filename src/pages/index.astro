---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import products from '../data/products.json';

const productos = [
	{ nombre: "Cargo Pant V1", precio: "95.00", cat: "Techwear" },
	{ nombre: "Oversize Hoodie", precio: "80.00", cat: "Urban Essentials" },
	{ nombre: "Utility Vest", precio: "120.00", cat: "Limited Edition" },
];
---

<Layout title="LocalMarket | Urban Elegance">
	<section class="px-8 py-20 max-w-7xl mx-auto">
		
		<div class="relative z-10 mb-20">
			<div class="flex items-center gap-3 mb-10">
				<span class="w-16 h-[1px] bg-[#facc15]"></span>
				<span class="text-[#facc15] text-[11px] font-black uppercase tracking-[0.5em]">Urban Standards</span>
			</div>

			<h1 class="text-7xl md:text-[10rem] font-black tracking-[-0.05em] leading-[0.85] uppercase italic mb-12
					   bg-gradient-to-r from-gray-400 via-gray-100 to-[#facc15] bg-clip-text text-transparent opacity-95">
				ESTILO <br/> RESILIENTE.
			</h1>

			<div class="max-w-md">
				<p class="text-gray-400 text-lg mb-10 font-light leading-relaxed">
					Diseño industrial para el día a día. Nuestra tienda local redefine la moda urbana con materiales de alta calidad y cortes precisos.
				</p>
				
				<div class="flex gap-4">
					<button class="bg-white text-black px-10 py-4 font-black uppercase text-[11px] tracking-widest hover:bg-[#facc15] transition-colors rounded-sm">
						Nueva Colección
					</button>
					<button class="border border-white/20 backdrop-blur-md px-10 py-4 font-black uppercase text-[11px] tracking-widest hover:bg-white/10 transition-colors rounded-sm">
						Ver Todo
					</button>
				</div>
			</div>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mt-20">
			{products.map((p, i) => (
				<div class="animate-reveal" style={`animation-delay: ${0.4 + (i * 0.1)}s`}>
					<Card 
						id={p.id}  title={p.nombre} 
						price={p.precio} 
						category={p.cat} 
						image={p.imagen} 
					/>
				</div>
			))}
		</div>
	</section>
</Layout>